{
  "name": "scoutagent",
  "version": "0.1.0",
  "description": "Autonomous shopping research agent — one request, one digest, delivered by email.",
  "private": true,
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/web/index.html','dist/web/index.html')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:web": "tsx watch src/web/server.ts",
    "run:slice": "tsx src/agent/run.ts",
    "run:slice:dry": "tsx src/agent/run.ts --dry-run",
    "start": "node dist/web/server.js"
  },
  "dependencies": {
    "openai": "^4.73.0",
    "@mozilla/readability": "^0.5.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsdom": "^25.0.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
