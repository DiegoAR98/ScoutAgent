# ─── Tetrate TARS (OpenAI-compatible LLM gateway) ───────────────────────
# OpenAI-compatible Chat Completions endpoint provided by Tetrate.
# Routes to multiple providers (Claude, GPT, etc.) by model id.
# All LLM calls MUST go through TARS (per SRS §2.5).
TARS_API_URL=https://your-tars-endpoint.tetrate.io/
TARS_API_KEY=
TARS_MODEL=claude-sonnet-4-6

# ─── SerpAPI ─────────────────────────────────────────────────────────────
SERPAPI_KEY=

# ─── EmailJS (digest delivery) ──────────────────────────────────────────
# Account: https://www.emailjs.com → Email Services / Email Templates / Account
# EMAIL_JS_SERVICE_ID:   the id of the connected email service in your account
# EMAIL_JS_TEMPLATE:     the template id (Mustache placeholders defined in template.html)
# EMAIL_JS_API_KEY:      EmailJS Public Key (the `user_id` field in their REST API)
# EMAIL_JS_PRIVATE_KEY:  EmailJS Private Key / access token — required for server-side
#                        sends, since EmailJS blocks non-browser calls without it
EMAIL_JS_SERVICE_ID=
EMAIL_JS_TEMPLATE=
EMAIL_JS_API_KEY=
EMAIL_JS_PRIVATE_KEY=

# ─── Web server ─────────────────────────────────────────────────────────
PORT=3000

# ─── Runtime ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
