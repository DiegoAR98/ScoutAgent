# ─── Tetrate TARS (OpenAI-compatible LLM gateway) ───────────────────────
# OpenAI-compatible Chat Completions endpoint provided by Tetrate.
# Routes to multiple providers (Claude, GPT, etc.) by model id.
# All LLM calls MUST go through TARS (per SRS §2.5).
TARS_API_URL=https://your-tars-endpoint.tetrate.io/
TARS_API_KEY=
TARS_MODEL=claude-sonnet-4-6

# ─── SerpAPI ─────────────────────────────────────────────────────────────
SERPAPI_KEY=

# ─── SendGrid ────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=scout@minasdigital.com
# Optional HMAC secret for verifying SendGrid event webhook (FR-21)
SENDGRID_WEBHOOK_PUBLIC_KEY=

# ─── PostgreSQL ──────────────────────────────────────────────────────────
# Local dev: sslmode=disable; production: sslmode=require (NFR-SEC-2 / §5.4)
DATABASE_URL=postgres://scout:scout@localhost:5432/scoutagent?sslmode=disable

# ─── Web server / unsubscribe ───────────────────────────────────────────
PORT=3000
# 32+ bytes of random hex; used to sign unsubscribe tokens (§5.5)
UNSUBSCRIBE_SECRET=replace-me-with-openssl-rand-hex-32

# ─── Runtime ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
